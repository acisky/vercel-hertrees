<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>New Games - Play Games Free Online | her-trees.com</title>
    <meta name="description"
        content="Browse the freshest indie puzzle and adventure releases curated by her-trees.com." />
    <meta name="robots" content="follow, index, max-snippet:-1, max-video-preview:-1, max-image-preview:large" />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

    <link rel="canonical" href="https://her-trees.com/new-games" />
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>

<body>
    <%-include('header')%>
        <main id="body">
            <section class="py-3">
                <div class="container">
                    <div class="row">
                        <div class="col-12 col-md-9 mx-auto">
                                <h1 class="fs-5 fw-bold mb-3"><span class="icon-title me-2"><svg fill="currentColor"
                                        viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                                        <path
                                            d="M7.51,26a5.48,5.48,0,0,1-1.44-.19A5.6,5.6,0,0,1,2.19,19l2.33-8.84A5.54,5.54,0,0,1,7.11,6.73a5.43,5.43,0,0,1,4.15-.54A5.52,5.52,0,0,1,14.7,9h2.6a5.49,5.49,0,0,1,3.44-2.81,5.43,5.43,0,0,1,4.15.54,5.57,5.57,0,0,1,2.59,3.41L29.81,19a5.6,5.6,0,0,1-3.89,6.83,5.43,5.43,0,0,1-4.15-.54,5.54,5.54,0,0,1-2.59-3.41L19,21H13l-.23.86a5.54,5.54,0,0,1-2.59,3.41A5.46,5.46,0,0,1,7.51,26ZM9.83,8a3.49,3.49,0,0,0-1.72.46,3.6,3.6,0,0,0-1.66,2.19L4.12,19.49A3.6,3.6,0,0,0,6.6,23.88a3.43,3.43,0,0,0,2.62-.34,3.54,3.54,0,0,0,1.66-2.19L11.5,19h9l.61,2.35a3.58,3.58,0,0,0,1.66,2.19,3.46,3.46,0,0,0,2.63.34,3.58,3.58,0,0,0,2.47-4.39l-2.33-8.84a3.55,3.55,0,0,0-1.65-2.19,3.46,3.46,0,0,0-2.63-.34,3.55,3.55,0,0,0-2.37,2.22l-.24.66h-5.3l-.24-.66a3.56,3.56,0,0,0-2.38-2.22A3.48,3.48,0,0,0,9.83,8Z" />
                                        <path d="M10,16a2,2,0,1,1,2-2A2,2,0,0,1,10,16Zm0-2Z" />
                                        <circle cx="22" cy="12" r="1" />
                                        <circle cx="22" cy="16" r="1" />
                                        <circle cx="20" cy="14" r="1" />
                                        <circle cx="24" cy="14" r="1" />
                                    </svg></span>New Games</h1>
                            <div class="row g-3">
                                <% newGames.forEach(game=> { %>
                                    <div class="col-6 col-md-2">
                                        <div class="game-card">
                                            <a href="/<%= game.slug %>" class="game-card-link rounded"
                                                title="<%= game.title %>">
                                                <div class="game-card-image rounded">
                                                    <div class="ratio ratio-1x1">
                                                        <img src="<%= game.thumb %>" class="object-fit-cover rounded"
                                                            alt="<%=game.title%>" />
                                                    </div>
                                                </div>
                                                <div class="game-card-title rounded-bottom">
                                                    <%= game.title %>
                                                </div>
                                            </a>
                                        </div>
                                    </div>
                                    <% }) %>
                            </div>
                            <article class="bg-content p-3 rounded mt-3">
                                Dive into the HER TREES new releases hub and discover the latest atmospheric puzzle,
                                narrative, and adventure experiences. Whether you are into strategic merging, quiet
                                brain teasers, or high-stakes experiments, there is always a fresh title to explore on
                                her-trees.com.
                            </article>
                        </div>
                    </div>
                </div>
            </section>
        </main>
        <%-include('footer')%>
</body>

</html>
