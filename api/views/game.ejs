<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>
        <%=metadata.title%> - Play Games Free Online
    </title>
    <meta name="description" content="<%-content.replace(/<[^>]*>/g, '').substring(0, 120)%>...">
    <meta name="robots" content="follow, index, max-snippet:-1, max-video-preview:-1, max-image-preview:large" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://her-trees.com/<%=metadata.slug%>" />
    <meta property="og:title" content="<%=metadata.title%> - Play Games Free Online" />
    <meta property="og:description" content="<%-content.replace(/<[^>]*>/g, '').substring(0, 120)%>..." />
    <meta property="og:image" content="https://her-trees.com<%=metadata.thumb%>" />

    <!-- X (Twitter) -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://her-trees.com/<%=metadata.slug%>" />
    <meta property="twitter:title" content="<%=metadata.title%> - Play Games Free Online" />
    <meta property="twitter:description" content="<%-content.replace(/<[^>]*>/g, '').substring(0, 120)%>..." />
    <meta property="twitter:image" content="https://her-trees.com<%=metadata.thumb%>" />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

    <link rel="canonical" href="https://her-trees.com/<%=metadata.slug%>" />
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>

<body>
    <%-include('header')%>
        <main id="body">
            <section class="py-3">
                <div class="container">
                    <div class="row">
                        <div class="col-12 col-md-9">
                            <div class="game-main p-0 p-md-3 rounded">
                                <div class="game-main-inner rounded">
                                    <div class="game-embed position-relative">
                                        <div class="game-iframe ratio ratio-16x9">
                                            <iframe src="/<%=metadata.slug%>.embed" title="<%=metadata.title%>"
                                                allowfullscreen class="rounded-top"></iframe>
                                        </div>
                                    </div>
                                    <div class="game-toolbar px-3 px-md-4 py-2 py-md-3">
                                        <div class="d-flex align-items-center justify-content-between">
                                            <div class="d-flex">
                                                <h1 class="m-0 fs-5 fw-bolder text-white">
                                                    <%=metadata.title%>
                                                </h1>
                                            </div>
                                            <div class="d-flex gap-2">
                                                <button class="btn" aria-label="Share"
                                                    onclick="shareGame('<%=metadata.slug%>')"><svg
                                                        xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                        viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                        class="lucide lucide-share2 h-5 w-5">
                                                        <circle cx="18" cy="5" r="3"></circle>
                                                        <circle cx="6" cy="12" r="3"></circle>
                                                        <circle cx="18" cy="19" r="3"></circle>
                                                        <line x1="8.59" x2="15.42" y1="13.51" y2="17.49"></line>
                                                        <line x1="15.41" x2="8.59" y1="6.51" y2="10.49"></line>
                                                    </svg></button><button class="btn" aria-label="Fullscreen"
                                                    onclick="fullScreen()"><svg xmlns="http://www.w3.org/2000/svg"
                                                        width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                        stroke-linejoin="round" class="lucide lucide-maximize2 h-5 w-5">
                                                        <polyline points="15 3 21 3 21 9"></polyline>
                                                        <polyline points="9 21 3 21 3 15"></polyline>
                                                        <line x1="21" x2="14" y1="3" y2="10"></line>
                                                        <line x1="3" x2="10" y1="21" y2="14"></line>
                                                    </svg></button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <article class="game-post bg-content p-3 rounded mt-3">
                                <%-content%>
                            </article>
                        </div>
                        <div class="col-12 col-md-3 mt-3 mt-md-0">
                            <div class="game-sidebar p-3 rounded mb-3">
                                <h2 class="fs-5 fw-bold mb-3"><span class="icon-title me-2"><svg viewBox="0 0 24 24"
                                            xmlns="http://www.w3.org/2000/svg">
                                            <path fill-rule="evenodd" clip-rule="evenodd"
                                                d="M10.0284 1.11813C9.69728 1.2952 9.53443 1.61638 9.49957 1.97965C9.48456 2.15538 9.46201 2.32986 9.43136 2.50363C9.3663 2.87248 9.24303 3.3937 9.01205 3.98313C8.5513 5.15891 7.67023 6.58926 5.96985 7.65195C3.57358 9.14956 2.68473 12.5146 3.06456 15.527C3.45234 18.6026 5.20871 21.7903 8.68375 22.9486C9.03 23.0641 9.41163 22.9817 9.67942 22.7337C10.0071 22.4303 10.0238 22.0282 9.94052 21.6223C9.87941 21.3244 9.74999 20.5785 9.74999 19.6875C9.74999 19.3992 9.76332 19.1034 9.79413 18.8068C10.3282 20.031 11.0522 20.9238 11.7758 21.5623C12.8522 22.5121 13.8694 22.8574 14.1722 22.9466C14.402 23.0143 14.6462 23.0185 14.8712 22.9284C17.5283 21.8656 19.2011 20.4232 20.1356 18.7742C21.068 17.1288 21.1993 15.3939 20.9907 13.8648C20.7833 12.3436 20.2354 10.9849 19.7537 10.0215C19.3894 9.29292 19.0534 8.77091 18.8992 8.54242C18.7101 8.26241 18.4637 8.04626 18.1128 8.00636C17.8332 7.97456 17.5531 8.06207 17.3413 8.24739L15.7763 9.61686C15.9107 7.44482 15.1466 5.61996 14.1982 4.24472C13.5095 3.24609 12.7237 2.47913 12.1151 1.96354C11.8094 1.70448 11.5443 1.50549 11.3525 1.36923C11.2564 1.30103 11.1784 1.24831 11.1224 1.21142C10.7908 0.99291 10.3931 0.923125 10.0284 1.11813ZM7.76396 20.256C7.75511 20.0744 7.74999 19.8842 7.74999 19.6875C7.75 18.6347 7.89677 17.3059 8.47802 16.0708C8.67271 15.6572 8.91614 15.254 9.21914 14.8753C9.47408 14.5566 9.89709 14.4248 10.2879 14.5423C10.6787 14.6598 10.959 15.003 10.9959 15.4094C11.2221 17.8977 12.2225 19.2892 13.099 20.0626C13.5469 20.4579 13.979 20.7056 14.292 20.8525C15.5 20.9999 17.8849 18.6892 18.3955 17.7882C19.0569 16.6211 19.1756 15.356 19.0091 14.1351C18.8146 12.7092 18.2304 11.3897 17.7656 10.5337L14.6585 13.2525C14.3033 13.5634 13.779 13.5835 13.401 13.3008C13.023 13.018 12.8942 12.5095 13.092 12.0809C14.4081 9.22933 13.655 6.97987 12.5518 5.38019C12.1138 4.74521 11.6209 4.21649 11.18 3.80695C11.0999 4.088 10.9997 4.39262 10.8742 4.71284C10.696 5.16755 10.4662 5.65531 10.1704 6.15187C9.50801 7.26379 8.51483 8.41987 7.02982 9.34797C5.57752 10.2556 4.71646 12.6406 5.04885 15.2768C5.29944 17.2643 6.20241 19.1244 7.76396 20.256Z"
                                                fill="currentColor" />
                                        </svg></span>You might also like
                                </h2>
                                <div class="row g-3">
                                    <% topGames.forEach(game=> { %>
                                        <div class="col-6">
                                            <div class="game-card">
                                                <a href="/<%= game.slug %>" class="game-card-link rounded"
                                                    title="<%= game.title %>">
                                                    <div class="game-card-image rounded">
                                                        <div class="ratio ratio-1x1">
                                                            <img src="<%= game.thumb %>"
                                                                class="object-fit-cover rounded"
                                                                alt="<%=game.title%>" />
                                                        </div>
                                                    </div>
                                                    <div class="game-card-title rounded-bottom">
                                                        <%= game.title %>
                                                    </div>
                                                </a>
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>
                            </div>

                            <div class="d-flex align-items-center justify-content-center mb-3">
                                <script>
                                    atOptions = {
                                        'key': '27790b62cf9772743c1106196c4a31a9',
                                        'format': 'iframe',
                                        'height': 250,
                                        'width': 300,
                                        'params': {}
                                    };
                                </script>
                                <script src="https://www.highperformanceformat.com/27790b62cf9772743c1106196c4a31a9/invoke.js"></script>
                            </div>

                            <div class="game-sidebar p-3 rounded mb-3">
                                <h2 class="fs-5 fw-bold mb-3"><span class="icon-title me-2"><svg fill="currentColor"
                                            viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                                            <path
                                                d="M7.51,26a5.48,5.48,0,0,1-1.44-.19A5.6,5.6,0,0,1,2.19,19l2.33-8.84A5.54,5.54,0,0,1,7.11,6.73a5.43,5.43,0,0,1,4.15-.54A5.52,5.52,0,0,1,14.7,9h2.6a5.49,5.49,0,0,1,3.44-2.81,5.43,5.43,0,0,1,4.15.54,5.57,5.57,0,0,1,2.59,3.41L29.81,19a5.6,5.6,0,0,1-3.89,6.83,5.43,5.43,0,0,1-4.15-.54,5.54,5.54,0,0,1-2.59-3.41L19,21H13l-.23.86a5.54,5.54,0,0,1-2.59,3.41A5.46,5.46,0,0,1,7.51,26ZM9.83,8a3.49,3.49,0,0,0-1.72.46,3.6,3.6,0,0,0-1.66,2.19L4.12,19.49A3.6,3.6,0,0,0,6.6,23.88a3.43,3.43,0,0,0,2.62-.34,3.54,3.54,0,0,0,1.66-2.19L11.5,19h9l.61,2.35a3.58,3.58,0,0,0,1.66,2.19,3.46,3.46,0,0,0,2.63.34,3.58,3.58,0,0,0,2.47-4.39l-2.33-8.84a3.55,3.55,0,0,0-1.65-2.19,3.46,3.46,0,0,0-2.63-.34,3.55,3.55,0,0,0-2.37,2.22l-.24.66h-5.3l-.24-.66a3.56,3.56,0,0,0-2.38-2.22A3.48,3.48,0,0,0,9.83,8Z" />
                                            <path d="M10,16a2,2,0,1,1,2-2A2,2,0,0,1,10,16Zm0-2Z" />
                                            <circle cx="22" cy="12" r="1" />
                                            <circle cx="22" cy="16" r="1" />
                                            <circle cx="20" cy="14" r="1" />
                                            <circle cx="24" cy="14" r="1" />
                                        </svg></span>New Games</h2>
                                <div class="row g-3">
                                    <% newGames.forEach(game=> { %>
                                        <div class="col-6">
                                            <div class="game-card">
                                                <a href="/<%= game.slug %>" class="game-card-link rounded"
                                                    title="<%= game.title %>">
                                                    <div class="game-card-image rounded">
                                                        <div class="ratio ratio-1x1">
                                                            <img src="<%= game.thumb %>"
                                                                class="object-fit-cover rounded"
                                                                alt="<%=game.title%>" />
                                                        </div>
                                                    </div>
                                                    <div class="game-card-title rounded-bottom">
                                                        <%= game.title %>
                                                    </div>
                                                </a>
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>
                            </div>
                            <div class="new-games text-center">
                                <a href="/new-games" class="btn">More Games</a>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
        <%-include('footer')%>
            <script type="text/javascript">
                function fullScreen() {
                    const iframe = document.querySelector('.game-iframe iframe');
                    if (document.fullscreenElement) {
                        document.exitFullscreen();
                    } else {
                        iframe.requestFullscreen();
                    }
                }

                function shareGame(slug) {
                    navigator.share({
                        title: 'HER TREES : PUZZLE DREAM',
                        text: 'Play HER TREES : PUZZLE DREAM on her-trees.com',
                        url: 'https://her-trees.com/' + slug
                    });
                }
            </script>
</body>

</html>
