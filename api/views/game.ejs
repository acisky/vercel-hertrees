<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>
        <%=metadata.title%> - Play Games Free Online
    </title>
    <meta name="description" content="<%-content.replace(/<[^>]*>/g, '').substring(0, 120)%>...">
    <meta name="robots" content="follow, index, max-snippet:-1, max-video-preview:-1, max-image-preview:large" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mergerot.co/<%=metadata.slug%>" />
    <meta property="og:title" content="<%=metadata.title%> - Play Games Free Online" />
    <meta property="og:description" content="<%-content.replace(/<[^>]*>/g, '').substring(0, 120)%>..." />
    <meta property="og:image" content="https://mergerot.co<%=metadata.thumb%>" />

    <!-- X (Twitter) -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://mergerot.co/<%=metadata.slug%>" />
    <meta property="twitter:title" content="<%=metadata.title%> - Play Games Free Online" />
    <meta property="twitter:description" content="<%-content.replace(/<[^>]*>/g, '').substring(0, 120)%>..." />
    <meta property="twitter:image" content="https://mergerot.co<%=metadata.thumb%>" />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

    <link rel="canonical" href="https://mergerot.co/<%=metadata.slug%>" />
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>

<body>
    <%-include('header')%>
        <main id="body">
            <section class="py-3">
                <div class="container">
                    <div class="game-hreo grid">
                        <!-- Main Content Column -->
                        <div class="g-col-1 g-col-md-3">
                            <div class="game-main p-0 p-md-3 rounded">
                                <div class="game-main-inner rounded">
                                    <div class="game-embed position-relative">
                                        <div class="game-iframe ratio ratio-16x9">
                                            <iframe src="/<%=metadata.slug%>.embed" title="<%=metadata.title%>"
                                                allowfullscreen class="rounded-top"></iframe>
                                        </div>
                                    </div>
                                    <div class="game-toolbar px-3 px-md-4 py-2 py-md-3">
                                        <div class="d-flex align-items-center justify-content-between">
                                            <div class="d-flex">
                                                <h1 class="m-0 fs-4 fw-bold text-white">
                                                    <%=metadata.title%>
                                                </h1>
                                            </div>
                                            <div class="d-flex">
                                                <button class="btn" aria-label="Share"
                                                    onclick="shareGame('<%=metadata.slug%>')"><svg
                                                        xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                        viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                        class="lucide lucide-share2 h-5 w-5">
                                                        <circle cx="18" cy="5" r="3"></circle>
                                                        <circle cx="6" cy="12" r="3"></circle>
                                                        <circle cx="18" cy="19" r="3"></circle>
                                                        <line x1="8.59" x2="15.42" y1="13.51" y2="17.49"></line>
                                                        <line x1="15.41" x2="8.59" y1="6.51" y2="10.49"></line>
                                                    </svg></button><button class="btn" aria-label="Fullscreen"
                                                    onclick="fullScreen()"><svg xmlns="http://www.w3.org/2000/svg"
                                                        width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                        stroke-linejoin="round" class="lucide lucide-maximize2 h-5 w-5">
                                                        <polyline points="15 3 21 3 21 9"></polyline>
                                                        <polyline points="9 21 3 21 3 15"></polyline>
                                                        <line x1="21" x2="14" y1="3" y2="10"></line>
                                                        <line x1="3" x2="10" y1="21" y2="14"></line>
                                                    </svg></button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-3">
                                <script async
                                    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4709943143417910"
                                    crossorigin="anonymous"></script>
                                <!-- autoads -->
                                <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-4709943143417910"
                                    data-ad-slot="1388952953" data-ad-format="auto"
                                    data-full-width-responsive="true"></ins>
                                <script>
                                    (adsbygoogle = window.adsbygoogle || []).push({});
                                </script>
                            </div>
                            <article class="game-post bg-white-alpha p-3 rounded mt-3">
                                <%-content%>
                            </article>
                        </div>
                        <div class="g-col-1 g-col-md-1 mt-3 mt-md-0">
                            <div class="mb-3">
                                <div class="g-col-2">
                                    <script async
                                        src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4709943143417910"
                                        crossorigin="anonymous"></script>
                                    <!-- autoads -->
                                    <ins class="adsbygoogle" style="display:block"
                                        data-ad-client="ca-pub-4709943143417910" data-ad-slot="1388952953"
                                        data-ad-format="auto" data-full-width-responsive="true"></ins>
                                    <script>
                                        (adsbygoogle = window.adsbygoogle || []).push({});
                                    </script>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <h2 class="fs-5 fw-bold text-white mb-3"><span class="icon-title me-2"><svg
                                            width="800px" height="800px" viewBox="0 0 24 24" fill="none"
                                            xmlns="http://www.w3.org/2000/svg">
                                            <path
                                                d="M14.9348 13.1725C15.3654 13.3446 15.5817 13.8402 15.3237 14.2255C15.0294 14.665 14.6493 15.0442 14.2032 15.3386C13.522 15.7881 12.7196 16.0185 11.9037 15.9988C11.0878 15.9792 10.2975 15.7104 9.6387 15.2287C9.20726 14.9131 8.8458 14.5161 8.573 14.0629C8.33384 13.6656 8.57376 13.181 9.01216 13.0299C9.45056 12.8788 9.91919 13.1274 10.2157 13.4839C10.3367 13.6294 10.4756 13.7603 10.63 13.8732C11.0122 14.1527 11.4708 14.3087 11.9441 14.3201C12.4175 14.3315 12.883 14.1978 13.2782 13.937C13.4379 13.8316 13.583 13.7076 13.7108 13.5681C14.0241 13.2262 14.5042 13.0005 14.9348 13.1725Z"
                                                fill="#ffffff" />
                                            <path
                                                d="M10 9C10 8.44772 9.55228 8 9 8C8.44772 8 8 8.44772 8 9V10C8 10.5523 8.44772 11 9 11C9.55228 11 10 10.5523 10 10V9Z"
                                                fill="#ffffff" />
                                            <path
                                                d="M16 9C16 8.44772 15.5523 8 15 8C14.4477 8 14 8.44772 14 9V10C14 10.5523 14.4477 11 15 11C15.5523 11 16 10.5523 16 10V9Z"
                                                fill="#ffffff" />
                                            <path fill-rule="evenodd" clip-rule="evenodd"
                                                d="M2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12ZM12 4C7.58172 4 4 7.58172 4 12C4 16.4183 7.58172 20 12 20C16.4183 20 20 16.4183 20 12C20 7.58172 16.4183 4 12 4Z"
                                                fill="#ffffff" />
                                        </svg></span>You might also like
                                </h2>
                                <div class="grid hero-games">
                                    <% topGames.forEach(game=> { %>
                                        <div class="g-col-1">
                                            <div class="game-card">
                                                <a href="/<%= game.slug %>" class="game-card-link rounded"
                                                    title="<%= game.title %>">
                                                    <div class="game-card-image rounded">
                                                        <div class="ratio ratio-1x1">
                                                            <img src="<%= game.thumb %>"
                                                                class="object-fit-cover rounded"
                                                                alt="<%=game.title%>" />
                                                        </div>
                                                    </div>
                                                    <div class="game-card-title rounded-bottom">
                                                        <%= game.title %>
                                                    </div>
                                                </a>
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>
                            </div>

                            <div class="mb-3">
                                <h2 class="fs-5 fw-bold text-white mb-3"><span class="icon-title me-2"><svg
                                            fill="#ffffff" width="800px" height="800px" viewBox="0 0 32 32" id="icon"
                                            xmlns="http://www.w3.org/2000/svg">
                                            <defs>
                                                <style>
                                                    .cls-1 {
                                                        fill: none;
                                                    }
                                                </style>
                                            </defs>
                                            <title>game--console</title>
                                            <path
                                                d="M7.51,26a5.48,5.48,0,0,1-1.44-.19A5.6,5.6,0,0,1,2.19,19l2.33-8.84A5.54,5.54,0,0,1,7.11,6.73a5.43,5.43,0,0,1,4.15-.54A5.52,5.52,0,0,1,14.7,9h2.6a5.49,5.49,0,0,1,3.44-2.81,5.43,5.43,0,0,1,4.15.54,5.57,5.57,0,0,1,2.59,3.41L29.81,19a5.6,5.6,0,0,1-3.89,6.83,5.43,5.43,0,0,1-4.15-.54,5.54,5.54,0,0,1-2.59-3.41L19,21H13l-.23.86a5.54,5.54,0,0,1-2.59,3.41A5.46,5.46,0,0,1,7.51,26ZM9.83,8a3.49,3.49,0,0,0-1.72.46,3.6,3.6,0,0,0-1.66,2.19L4.12,19.49A3.6,3.6,0,0,0,6.6,23.88a3.43,3.43,0,0,0,2.62-.34,3.54,3.54,0,0,0,1.66-2.19L11.5,19h9l.61,2.35a3.58,3.58,0,0,0,1.66,2.19,3.46,3.46,0,0,0,2.63.34,3.58,3.58,0,0,0,2.47-4.39l-2.33-8.84a3.55,3.55,0,0,0-1.65-2.19,3.46,3.46,0,0,0-2.63-.34,3.55,3.55,0,0,0-2.37,2.22l-.24.66h-5.3l-.24-.66a3.56,3.56,0,0,0-2.38-2.22A3.48,3.48,0,0,0,9.83,8Z"
                                                transform="translate(0)" />
                                            <path d="M10,16a2,2,0,1,1,2-2A2,2,0,0,1,10,16Zm0-2Z"
                                                transform="translate(0)" />
                                            <circle cx="22" cy="12" r="1" />
                                            <circle cx="22" cy="16" r="1" />
                                            <circle cx="20" cy="14" r="1" />
                                            <circle cx="24" cy="14" r="1" />
                                            <rect id="_Transparent_Rectangle_" data-name="&lt;Transparent Rectangle&gt;"
                                                class="cls-1" width="32" height="32" />
                                        </svg></span>New Games</h2>
                                <div class="grid hero-games">
                                    <% newGames.forEach(game=> { %>
                                        <div class="g-col-1">
                                            <div class="game-card">
                                                <a href="/<%= game.slug %>" class="game-card-link rounded"
                                                    title="<%= game.title %>">
                                                    <div class="game-card-image rounded">
                                                        <div class="ratio ratio-1x1">
                                                            <img src="<%= game.thumb %>"
                                                                class="object-fit-cover rounded"
                                                                alt="<%=game.title%>" />
                                                        </div>
                                                    </div>
                                                    <div class="game-card-title rounded-bottom">
                                                        <%= game.title %>
                                                    </div>
                                                </a>
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>
                            </div>
                            <div class="new-games text-center">
                                <a href="/new-games" class="btn">More Games</a>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
        <%-include('footer')%>
            <script type="text/javascript">
                function fullScreen() {
                    const iframe = document.querySelector('.game-iframe iframe');
                    if (document.fullscreenElement) {
                        document.exitFullscreen();
                    } else {
                        iframe.requestFullscreen();
                    }
                }

                function shareGame(slug) {
                    navigator.share({
                        title: 'Merge Rot',
                        text: 'Play Merge Rot on your device',
                        url: 'https://mergerot.com/' + slug
                    });
                }
            </script>
</body>

</html>