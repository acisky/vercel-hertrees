<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title><%=metadata.title%></title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>

<body>
    <div class="game-embed w-100 h-100 position-relative">
        <div class="game-iframe">
            <iframe src="about:blank" data-src="<%=metadata.iframe%>" title="<%=metadata.title%>"
                allowfullscreen class="w-100 h-100 rounded-top"></iframe>
        </div>
        <div class="game-cover rounded-top h-100 w-100 position-absolute left-0 top-0 z-index-1"
            style="background-image:url('<%=metadata.thumb%>')">
            <div class="position-absolute top-50 start-50 translate-middle z-2">
                <div class="d-flex flex-column gap-3">
                    <div class="ratio ratio-16x9">
                        <img src="<%=metadata.thumb%>" class="object-fit-cover rounded" alt="<%=metadata.title%>">
                    </div>
                    <strong class="d-block fs-4 fw-bold text-white text-center"><%=metadata.title%></strong>
                    <div class="d-flex justify-content-center">
                        <button class="btn d-flex align-items-center gap-3">
                            <span><svg width="800px" height="800px" viewBox="0 0 24 24" fill="none"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <path
                                        d="M20.4086 9.35258C22.5305 10.5065 22.5305 13.4935 20.4086 14.6474L7.59662 21.6145C5.53435 22.736 3 21.2763 3 18.9671L3 5.0329C3 2.72368 5.53435 1.26402 7.59661 2.38548L20.4086 9.35258Z"
                                        stroke="#ffffff" stroke-width="1.5" />
                                </svg></span>
                            <span>Play Game</span></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script type="text/javascript">
        document.querySelector('.game-cover .btn').addEventListener('click', function() {
            // Hide the game cover
            document.querySelector('.game-cover').style.display = 'none';
            
            // Set iframe src from data-src
            const iframe = document.querySelector('.game-iframe iframe');
            iframe.src = iframe.dataset.src;
        });
    </script>
</body>

</html>